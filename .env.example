# === OPENAI ===
# Pegue em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# === SUPABASE ===
# Pegue em: Settings > API do seu projeto Supabase
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxx

# === Z-API ===
# Pegue no painel da Z-API depois de criar a instância
ZAPI_INSTANCE_ID=xxxxxxxxxxxxxxxxxx
ZAPI_TOKEN=xxxxxxxxxxxxxxxxxx
ZAPI_CLIENT_TOKEN=xxxxxxxxxxxxxxxxxx

# === WhatsApp da Cia (Mila) ===
# Número da Mila no formato internacional sem + nem espaços
MILA_PHONE_NUMBER=5531996058310

# === Grupo interno de notificação ===
# ID do grupo "Leads Cia Fitness" no WhatsApp
# Será preenchido depois que a Z-API estiver conectada
GROUP_LEADS_ID=

# === Configurações operacionais ===
# Ambiente: development ou production
NODE_ENV=production

# Porta do servidor (Railway sobrescreve automaticamente)
PORT=3000

# Modo da Mila: production (responde leads) ou test (só você)
MILA_MODE=test

# Telefone autorizado em modo test (seu número pessoal)
TEST_PHONE_NUMBER=
